# ── LLM ──────────────────────────────────────────────────────────────────────
# Get from: https://platform.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Search ────────────────────────────────────────────────────────────────────
# Get from: https://api.search.brave.com → Developer Dashboard (free 2k req/mo)
BRAVE_API_KEY=BSA...

# Get from: https://www.reddit.com/prefs/apps → create app (type: script)
REDDIT_CLIENT_ID=...
REDDIT_CLIENT_SECRET=...

# ── Affiliate / cashback ──────────────────────────────────────────────────────
# Get from: https://rakutenadvertising.com → Publisher signup (takes 1-2 days)
RAKUTEN_API_KEY=...

# ── Validation browser (optional — add if Playwright gets blocked) ────────────
# Get from: https://browserbase.com
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=

# ── Cache & DB ────────────────────────────────────────────────────────────────
# Local dev defaults — Render injects real values automatically in production
REDIS_URL=redis://localhost:6379
DATABASE_URL=postgresql://postgres:dev@localhost:5432/pricehunt

# ── App ───────────────────────────────────────────────────────────────────────
# Local dev — Render replaces with the live frontend URL in production
FRONTEND_URL=http://localhost:5173
