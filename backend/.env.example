# ════════════════════════════════════════════════════════════════════════════
# REQUIRED — the agent does not start without these two keys
# ════════════════════════════════════════════════════════════════════════════

# Get from: https://platform.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# Get from: https://app.tavily.com → Overview (free 1k req/mo, no credit card)
TAVILY_API_KEY=tvly-...


# ════════════════════════════════════════════════════════════════════════════
# OPTIONAL — future development, leave empty to start
# ════════════════════════════════════════════════════════════════════════════

# Reddit API — fresh codes from r/deals (blocked by new 2026 policy, skip for now)
# Get from: https://www.reddit.com/prefs/apps → create app (type: script)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# Rakuten Affiliate — cashback rates + revenue model (requires full account setup)
# Get from: https://rakutenadvertising.com → Publisher signup (takes 1-2 days)
RAKUTEN_API_KEY=

# Browserbase — managed cloud browsers if Playwright gets blocked on certain sites
# Get from: https://browserbase.com
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=

# Redis — code cache + agent memory (optional, agent works without it)
# Leave empty for Render (requires credit card even on free tier)
# For local dev with Redis installed: redis://localhost:6379
REDIS_URL=

# PostgreSQL — long-term run history and analytics (optional)
DATABASE_URL=


# ════════════════════════════════════════════════════════════════════════════
# APP
# ════════════════════════════════════════════════════════════════════════════

# Local dev only — Render injects the real frontend URL automatically
FRONTEND_URL=http://localhost:5173
